# ─────────────────────────────────────────────
#  Voice Bot – Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# API Settings
APP_NAME="VoiceBot Customer Support"
APP_VERSION="1.0.0"
APP_HOST="0.0.0.0"
APP_PORT=8000
DEBUG=false

# ASR Settings
ASR_MODEL=base          # tiny | base | small | medium | large
ASR_LANGUAGE=en         # ISO language code
ASR_DEVICE=cpu          # cpu | cuda

# Intent Classifier Settings
INTENT_MODEL_DIR=./models/intent_classifier
INTENT_BASE_MODEL=bert-base-uncased
INTENT_CONFIDENCE_THRESHOLD=0.5
INTENT_MAX_LENGTH=128

# TTS Settings
TTS_ENGINE=gtts         # gtts | pyttsx3
TTS_LANGUAGE=en
TTS_SLOW=false
TTS_RATE=150            # words per minute (pyttsx3 only)
TTS_VOLUME=1.0          # 0.0 – 1.0 (pyttsx3 only)

# Logging
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# Model Training
TRAIN_EPOCHS=5
TRAIN_BATCH_SIZE=16
TRAIN_LR=2e-5
TRAIN_DATA_PATH=./data/intent_dataset.csv
